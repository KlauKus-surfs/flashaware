# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lightning
POSTGRES_PASSWORD=lightning_dev
POSTGRES_DB=lightning_risk

# JWT Authentication
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=8h

# ── Server ──────────────────────────────────────────────────
SERVER_PORT=4000
NODE_ENV=development
LOG_LEVEL=                                # pino level (trace/debug/info/warn/error). Empty = "debug" in dev, "info" in prod.
CORS_ORIGIN=                              # leave empty for dev (allows all); set to frontend URL in production
APP_URL=                                  # public URL of the frontend, e.g. https://app.flashaware.com — used to build invite links in emails
SERVER_URL=                               # public URL of the API. Used to build /a/<token> ack links delivered in emails/SMS, and the Twilio status-callback URL. Empty = production fallback.

# EUMETSAT Data Store
EUMETSAT_CONSUMER_KEY=your-consumer-key
EUMETSAT_CONSUMER_SECRET=your-consumer-secret
EUMETSAT_COLLECTION_ID=EO:EUM:DAT:0691

# Email Alerts (Nodemailer — required for alert emails to be sent)
# Gmail example: use an App Password (not your account password)
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=<API_KEY>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM=lightning-alerts@yourdomain.com

# Twilio — SMS & WhatsApp alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1xxxxxxxxxx                   # SMS sender number
TWILIO_WHATSAPP_FROM=+1xxxxxxxxxx          # WhatsApp-enabled number (same as TWILIO_FROM on Fly)

# WhatsApp Content Template SIDs (run server/scripts/create-whatsapp-templates.ts to generate)
# Per-state templates (2 vars: {{1}}=location, {{2}}=detail) — preferred
TWILIO_WA_TEMPLATE_STOP=
TWILIO_WA_TEMPLATE_PREPARE=
TWILIO_WA_TEMPLATE_HOLD=
TWILIO_WA_TEMPLATE_ALL_CLEAR=
TWILIO_WA_TEMPLATE_DEGRADED=
# Generic fallback template (3 vars: {{1}}=location, {{2}}=status, {{3}}=detail)
TWILIO_WHATSAPP_TEMPLATE_SID=HX1f0d10338bf716a73d1e906edfe343e4

# Ingestion
INGESTION_INTERVAL_SEC=120
RISK_ENGINE_INTERVAL_SEC=60

# Alert dispatch fan-out: how many recipients are processed in parallel
# during dispatchAlerts. Within each recipient the three channels (email /
# SMS / WhatsApp) always run via Promise.all; this cap bounds the total
# in-flight network work so a 50-recipient STOP doesn't open dozens of
# SMTP connections at once or trip Twilio's per-account QPS. Default 8.
DISPATCH_CONCURRENCY=8

# Throttle window (minutes) for the org-level "EUMETSAT feed degraded /
# restored" digest emitted by riskEngine when the feed transitions. A
# second notice of the same kind for the same org inside this window is
# suppressed via a query against the alerts table. Default 60.
FEED_NOTICE_THROTTLE_MIN=60

# In-process TTL for getOrgSettingsCached (alertService dispatch /
# escalation / feed-health notice all read this). Settings mutations
# (settingsRoutes PUT) call clearOrgSettingsCache so admins see their
# own changes immediately; this only bounds the propagation lag for
# changes made on a different machine. Default 10000ms.
ORG_SETTINGS_CACHE_TTL_MS=10000

# Multi-machine fan-out (optional). When set, socket.io broadcasts are
# distributed via Redis so a state change on machine A reaches a client
# connected to machine B. Leave empty for single-machine deployments —
# the default in-memory adapter is correct there. REQUIRED in production
# when FLY_MIN_MACHINES_RUNNING > 1; boot refuses to start without it
# (see assertWebsocketScalePrereqs in server/websocket.ts).
REDIS_URL=

# ── Retention (POPIA-aligned) ───────────────────────────────
DATA_RETENTION_DAYS=30                    # full purge of flash_events, risk_states, alerts older than this
ALERT_PII_SCRUB_DAYS=7                    # earlier window: scrub email/phone/twilio_sid from alerts but keep state+time
ORG_HARD_DELETE_DAYS=30                   # grace period after soft-delete before an org's rows are physically removed

# ── Demo seeding (DO NOT enable in production) ──────────────
SEED_DEMO_ADMIN=                          # "true" seeds admin@flashaware.com super-admin (dev/demo only) — placeholder password forces a rotation on first login
SEED_DEMO_ADMIN_PASSWORD=                 # Optional override for the SEED_DEMO_ADMIN seed password. Default = "admin123" (still on the BANNED_PASSWORDS rotation gate). Hashed at boot, never stored in source.
SEED_DEMO_LOCATIONS=                      # "true" seeds Johannesburg/Sun City/Rustenburg sample locations (fresh DB only)
